+
+// ====== Patch for GCC 4.8 ======
+#if !defined(__clang__) && defined(__GNUC__) && (__GNUC__ == 4) && (__GNUC_MINOR__ == 8)
+#include <memory>
+namespace std
+{
+template <class T, class... ArgsT>
+unique_ptr<T> make_unique(ArgsT &&...args)
+{
+  return unique_ptr<T>(new T(std::forward<ArgsT>(args)...));
+}
+}  // namespace std
+#endif
