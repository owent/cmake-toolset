diff --git a/CMakeLists.txt b/CMakeLists.txt
index e103c40..40370dd 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -22,6 +22,17 @@ set(CPACK_RESOURCE_FILE_README ${zlib_SOURCE_DIR}/README)
 option(ZLIB_BUILD_TESTING "Enable Zlib Examples as tests" ON)
 option(ZLIB_BUILD_SHARED "Enable building zlib shared library" ON)
 option(ZLIB_BUILD_STATIC "Enable building zlib static library" ON)
+
+# Respect BUILD_SHARED_LIBS
+if(DEFINED BUILD_SHARED_LIBS OR DEFINED CACHE{BUILD_SHARED_LIBS})
+  if(BUILD_SHARED_LIBS)
+    set(ZLIB_BUILD_SHARED ON)
+    set(ZLIB_BUILD_STATIC OFF)
+  else()
+    set(ZLIB_BUILD_SHARED OFF)
+    set(ZLIB_BUILD_STATIC ON)
+  endif()
+endif()
 option(ZLIB_INSTALL "Enable installation of zlib" ON)
 option(ZLIB_PREFIX "prefix for all types and library functions, see zconf.h.in"
        OFF)
@@ -150,7 +161,7 @@ set(ZLIB_SRCS
     zutil.c)
 
 if(WIN32)
-    set(zlib_static_suffix "s")
+    set(zlib_static_suffix "libstatic")
     set(CMAKE_DEBUG_POSTFIX "d")
 endif(WIN32)
 
diff --git a/zlibConfig.cmake.in b/zlibConfig.cmake.in
index 8252ab3..85038b0 100644
--- a/zlibConfig.cmake.in
+++ b/zlibConfig.cmake.in
@@ -9,10 +9,18 @@ if(ZLIB_FIND_COMPONENTS)
             set(ZLIB_NOT_FOUND_MESSAGE "Unsupported component: ${_comp}")
         endif(NOT _comp IN_LIST _ZLIB_supported_components)
 
-        include("${CMAKE_CURRENT_LIST_DIR}/ZLIB-${_comp}.cmake")
+        include("${CMAKE_CURRENT_LIST_DIR}/ZLIB-${_comp}.cmake" OPTIONAL)
     endforeach(_comp ${ZLIB_FIND_COMPONENTS})
 else(ZLIB_FIND_COMPONENTS)
     foreach(_component_config IN LISTS _ZLIB_supported_components)
-        include("${CMAKE_CURRENT_LIST_DIR}/ZLIB-${_component_config}.cmake")
+        include("${CMAKE_CURRENT_LIST_DIR}/ZLIB-${_component_config}.cmake" OPTIONAL)
     endforeach(_component_config IN LISTS _ZLIB_supported_components)
 endif(ZLIB_FIND_COMPONENTS)
+
+# Provide ZLIB::ZLIB target for compatibility when only static library is built
+if(NOT TARGET ZLIB::ZLIB)
+    if(TARGET ZLIB::ZLIBSTATIC)
+        add_library(ZLIB::ZLIB INTERFACE IMPORTED)
+        set_target_properties(ZLIB::ZLIB PROPERTIES INTERFACE_LINK_LIBRARIES ZLIB::ZLIBSTATIC)
+    endif()
+endif()
